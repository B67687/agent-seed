#!/bin/bash
# agent-seed: self-evaluation framework
#
# Runs capability checks against the repo, scores them,
# and outputs structured results for the improvement loop.
#
# Usage: bash scripts/eval
#   --verbose   print per-check details
#   --score     numeric score only (for tracking)
#   --json      machine-readable output
set -e

MODE="normal"  # normal | verbose | score | json

for arg in "$@"; do
  case "$arg" in
    --verbose) MODE="verbose" ;;
    --score)   MODE="score"   ;;
    --json)    MODE="json"    ;;
  esac
done

CHECKS_TOTAL=0
CHECKS_PASS=0
CHECKS_FAIL=0
RESULTS=""

verbose_echo() {
  if [ "$MODE" = "verbose" ]; then
    echo "$1"
  fi
}

pass() {
  local check="$1"
  local detail="${2:-}"
  CHECKS_TOTAL=$((CHECKS_TOTAL + 1))
  CHECKS_PASS=$((CHECKS_PASS + 1))
  RESULTS="${RESULTS}PASS|${check}|${detail}"$'\n'
  verbose_echo "  ✓ $check"
}

fail() {
  local check="$1"
  local detail="${2:-}"
  CHECKS_TOTAL=$((CHECKS_TOTAL + 1))
  CHECKS_FAIL=$((CHECKS_FAIL + 1))
  RESULTS="${RESULTS}FAIL|${check}|${detail}"$'\n'
  verbose_echo "  ✗ $check — ${detail}"
}

section() {
  if [ "$MODE" = "verbose" ]; then
    echo ""
    echo "--- $1 ---"
  fi
}

run_check() {
  local check_name="$1"
  shift
  if "$@"; then
    pass "$check_name"
  else
    fail "$check_name"
  fi
}

# ────────────────────────────────────────────
# Checks
# ────────────────────────────────────────────

section "Repo Integrity"

run_check "GOAL.md exists"        test -f GOAL.md
run_check "CHANGELOG.md exists"   test -f CHANGELOG.md
run_check "AGENTS.md exists"      test -f AGENTS.md
run_check ".opencode.jsonc exists" test -f .opencode.jsonc
run_check "README.md exists"      test -f README.md
run_check ".gitignore exists"     test -f .gitignore

section "Scripts"

for s in scripts/*; do
  [ -f "$s" ] || continue
  name="${s#scripts/}"
  run_check "$name executable" test -x "$s"
  run_check "$name shebang"    head -1 "$s" | grep -q '^#!/'
done

section "Git"

CLEAN=$(git status --short 2>/dev/null)
run_check "working tree clean" test -z "$CLEAN"

COMMIT_COUNT=$(git log --oneline 2>/dev/null | wc -l)
run_check "has commits ($COMMIT_COUNT)" test "$COMMIT_COUNT" -ge 1

LAST_MSG=$(git log -1 --format=%s 2>/dev/null)
run_check "last commit: $LAST_MSG" test -n "$LAST_MSG"

section "Capabilities"

run_check "self-eval exists"     test -f scripts/eval
run_check "improve exists"       test -f scripts/improve
run_check "model config exists"  test -f .model-config.json
run_check "tests exist"          bash -c 'test -d tests && ls -A tests/ 2>/dev/null | grep -q .'

section "Harness Integrity"

# Self-check: eval can run without errors
if [ "$MODE" != "score" ] && [ "$MODE" != "json" ]; then
  pass "eval self-check"
fi

# ────────────────────────────────────────────
# Output
# ────────────────────────────────────────────

SCORE=0
if [ "$CHECKS_TOTAL" -gt 0 ]; then
  SCORE=$((CHECKS_PASS * 100 / CHECKS_TOTAL))
fi

case "$MODE" in
  score)
    echo "$SCORE"
    ;;
  json)
    echo "{"
    echo "  \"score\": $SCORE,"
    echo "  \"total\": $CHECKS_TOTAL,"
    echo "  \"passed\": $CHECKS_PASS,"
    echo "  \"failed\": $CHECKS_FAIL,"
    echo "  \"checks\": ["
    FIRST=true
    while IFS='|' read -r status name detail; do
      [ -z "$name" ] && continue
      if [ "$FIRST" = true ]; then
        FIRST=false
      else
        echo ","
      fi
      echo -n "    {\"check\": \"$name\", \"status\": \"$status\", \"detail\": \"$detail\"}"
    done <<< "$RESULTS"
    echo ""
    echo "  ]"
    echo "}"
    ;;
  normal|verbose)
    echo ""
    echo "=== results ==="
    echo "  passed: $CHECKS_PASS / $CHECKS_TOTAL"
    echo "  score:  $SCORE/100"
    if [ $CHECKS_FAIL -gt 0 ]; then
      echo ""
      echo "  failing checks:"
      while IFS='|' read -r status name detail; do
        if [ "$status" = "FAIL" ]; then
          echo "    - $name ($detail)"
        fi
      done <<< "$RESULTS"
    fi
    ;;
esac
