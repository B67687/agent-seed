#!/bin/bash
# agent-seed: self-improvement bootstrap
#
# Aggregates project state to seed the next improvement decision.
# Uses scripts/eval --json for capability analysis.
#
# Usage: bash scripts/improve
set -e

echo "=== agent-seed :: self-improvement loop ==="
echo ""

# 1. Goal
echo "--- GOAL ---"
cat GOAL.md 2>/dev/null || echo "(missing GOAL.md)"
echo ""

# 2. Changelog (last 5 entries)
echo "--- CHANGELOG (tail) ---"
tail -20 CHANGELOG.md 2>/dev/null || echo "(missing CHANGELOG.md)"
echo ""

# 3. Git state
echo "--- GIT STATUS ---"
git status --short 2>/dev/null || echo "(not a git repo)"
echo ""

echo "--- RECENT COMMITS ---"
git log --oneline -5 2>/dev/null || echo "(no commits)"
echo ""

# 4. File overview
echo "--- PROJECT TREE ---"
find . -maxdepth 2 -not -path './.git/*' -not -path './.git' \
  | sort \
  | head -40
echo ""

# 5. Gap analysis — from eval
echo "--- EVAL SUMMARY ---"
if command -v jq >/dev/null 2>&1 && [ -f scripts/eval ]; then
  EVAL_JSON=$(bash scripts/eval --json 2>/dev/null || echo "")
  if [ -n "$EVAL_JSON" ]; then
    SCORE=$(echo "$EVAL_JSON" | jq -r '.score')
    PASSED=$(echo "$EVAL_JSON" | jq -r '.passed')
    TOTAL=$(echo "$EVAL_JSON" | jq -r '.total')
    echo "  score:  $SCORE/100"
    echo "  passed: $PASSED / $TOTAL"
    echo ""

    # Show failing checks
    FAILURES=$(echo "$EVAL_JSON" | jq -r '.checks[] | select(.status == "FAIL") | "  ✗ \(.check)"' 2>/dev/null)
    if [ -n "$FAILURES" ]; then
      echo "  failing checks:"
      echo "$FAILURES"
    fi
    echo ""

    # Suggest next steps based on failures
    echo "--- SUGGESTED NEXT STEPS ---"
    echo "$EVAL_JSON" | jq -r '.checks[] | select(.status == "FAIL") | .check' 2>/dev/null | while read -r check; do
      case "$check" in
        *"model config"*)     echo "  [+] Create .model-config.json" ;;
        *"tests"*)            echo "  [+] Create tests/ — add verification" ;;
        *"route"*)            echo "  [+] Create scripts/route — model resolver" ;;
        *"eval"*)             echo "  [+] Create scripts/eval — measurement" ;;
        *"improve"*)          echo "  [+] Create scripts/improve — iteration loop" ;;
        "working tree clean"*) echo "  [+] Commit working changes" ;;
        *)                    echo "  [+] Fix: $check" ;;
      esac
    done
    echo ""
  else
    echo "  (eval JSON failed — check scripts/eval)"
    echo ""
  fi
else
  echo "  (jq or scripts/eval not available)"
  echo ""
fi

echo "=== end ==="
