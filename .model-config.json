{
  "version": 1,
  "comment": "Model-agnostic routing for agent-seed daemon",
  "providers": {
    "deepseek": {
      "type": "api",
      "base_url": "https://api.deepseek.com/v1",
      "api_key_env": "DEEPSEEK_API_KEY",
      "models": {
        "deepseek-chat": { "cost_tier": "paid", "speed": "fast" }
      }
    },
    "local": {
      "type": "local",
      "base_url": "http://localhost:11434/v1",
      "api_key_env": null,
      "models": {
        "qwen3.6:27b": { "cost_tier": "free", "speed": "slow" }
      }
    }
  },
  "routes": {
    "create": {
      "model": "deepseek-chat",
      "provider": "deepseek",
      "access": "read_write",
      "description": "CREATE cycles — uses fast cloud model for file generation"
    },
    "explore": {
      "model": "qwen3.6:27b",
      "provider": "local",
      "access": "read_only",
      "description": "EXPLORE cycles — uses free local model for read-only discovery"
    }
  },
  "fallback_chain": ["deepseek-chat", "qwen3.6:27b"]
}
